# 환경변수 설정 예시 (.env.example)
# 이 파일을 .env로 복사하여 값을 수정하세요

SECRET_KEY=여기에-충분히-긴-랜덤-문자열을-넣으세요-최소-32자
DEBUG=false
DATABASE_URL=sqlite:///company.db
HOST=0.0.0.0
PORT=5000

# 보안 설정
BCRYPT_ROUNDS=12
JWT_EXPIRY_HOURS=24

# 파일 업로드
MAX_UPLOAD_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_LOGIN=10/minute

# 초기 관리자
ADMIN_PASSWORD=ChangeMe!Str0ng
